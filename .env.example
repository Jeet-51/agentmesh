# ── LLM keys ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=          # Claude Haiku — not needed if using Gemini only
GOOGLE_API_KEY=             # Gemini Flash (required for orchestrator + research + synthesis)

# ── Optional integrations ────────────────────────────────────────────────────
LANGSMITH_API_KEY=          # LangSmith tracing (optional but recommended)
TAVILY_API_KEY=             # Tavily web search (research agent — falls back to DuckDuckGo)

# ── Service URLs (used inside Docker network; do not change for local dev) ───
ORCHESTRATOR_URL=http://orchestrator:8001
RESEARCH_AGENT_URL=http://research:8002
SYNTHESIS_AGENT_URL=http://synthesis:8003
GATEWAY_URL=http://gateway:8000

# ── MCP tool server URLs (used by synthesis agent) ───────────────────────────
YFINANCE_TOOL_URL=http://yfinance-tool:8011/sse
WIKIPEDIA_TOOL_URL=http://wikipedia-tool:8012/sse
EDGAR_TOOL_URL=http://edgar-tool:8013/sse

# ── Gateway config ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GATEWAY_POLL_INTERVAL=2.5   # seconds between orchestrator status polls
GATEWAY_SSE_KEEPALIVE=25.0  # seconds before sending SSE ping keepalive

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_FORMAT=json             # "json" for Docker log drivers, anything else = ConsoleRenderer
